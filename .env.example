COMPOSE_PROFILES=core,dataops

# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=devops123
POSTGRES_DB=devops_db
DB_HOST=db
DB_PORT=5432
DATABASE__URI=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${DB_HOST}:${DB_PORT}/${POSTGRES_DB}

# RabbitMQ Configuration
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_HOST=mq
RABBITMQ_PORT=5672
RABBIT_HOST=mq
RABBITMQ__HOST=${RABBIT_HOST}
RABBITMQ__USER=${RABBITMQ_DEFAULT_USER}
RABBITMQ__PASSWORD=${RABBITMQ_DEFAULT_PASS}

# Application Paths
STORAGE__DATA_DIR=/app/data

# Plugin Management (Allowlist for Autodiscovery)
PLUGIN__ENABLED_PLUGINS=gitlab,sonarqube,nexus,zentao

# GitLab Integration
GITLAB__URL=https://gitlab.com
GITLAB__PRIVATE_TOKEN=
GITLAB__CLIENT_ID=
GITLAB__CLIENT_SECRET=
GITLAB__REDIRECT_URI=
GITLAB__VERIFY_SSL=True

# SonarQube Integration
SONARQUBE__URL=
SONARQUBE__TOKEN=
SONARQUBE__SYNC_INTERVAL_HOURS=24
SONARQUBE__SYNC_ISSUES=False

# Jenkins Integration
JENKINS__URL=
JENKINS__USER=
JENKINS__TOKEN=
JENKINS__SYNC_INTERVAL_HOURS=12

# ZenTao (禅道) Integration
ZENTAO__URL=
ZENTAO__TOKEN=
ZENTAO__SYNC_INTERVAL_HOURS=12

# AI / LLM Configuration
AI__API_KEY=
AI__BASE_URL=https://api.openai.com/v1
AI__MODEL=gpt-4o

# Authentication & Registration
# 允许注册的邮箱域名，多个用逗号分隔 (例如: example.com,company.com)
AUTH__ALLOWED_DOMAINS=
AUTH__SECRET_KEY=your-secret-key-keep-it-secret
AUTH__ADMIN_API_TOKEN=admin_secret_token_2025

# Logging
LOGGING__LEVEL=INFO

# Scheduler
SCHEDULER__SYNC_INTERVAL_MINUTES=10

# SLA Thresholds (Hours)
SLA__P0=8
SLA__P1=24
SLA__P2=73
SLA__P3=120
SLA__P4=240
SLA__DEFAULT=48

# Nexus Docker Registry (Fallback Mechanism)
NEXUS_DOCKER_REGISTRY=192.168.5.64:8082
